# Required on Vercel for persistent data
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=bee2gether

# Required on Vercel for image uploads
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=<supabase-secret-key>
SUPABASE_BUCKET=event-images

# Recommended on Vercel
FRONTEND_ORIGIN=*

# Optional, keep unset when frontend and API are deployed in the same Vercel project
# VITE_API_BASE_URL=
# VITE_API_CODE=vercel-demo

# Optional, keep unset or false in production
# USE_MEMORY_DB=false
